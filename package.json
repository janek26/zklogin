{
  "name": "zklogin-native-wallet",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "pnpm --dir apps/web build",
    "typecheck": "pnpm --dir apps/web typecheck",
    "test": "pnpm --dir apps/web test",
    "test:contracts": "cd contracts && forge test",
    "snapshot:jwks": "node scripts/snapshot-google-jwks.mjs",
    "app-id": "node scripts/make-app-id.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs"
  },
  "devDependencies": {
    "@openzeppelin/merkle-tree": "1.0.8",
    "@shield-labs/zklogin": "0.6.1",
    "viem": "2.55.1"
  },
  "pnpm": {
    "overrides": {
      "@aztec/bb.js": "0.65.2",
      "@noir-lang/noir_js": "1.0.0-beta.0",
      "@shield-labs/zklogin-contracts": "0.5.0"
    }
  },
  "overrides": {
    "@aztec/bb.js": "0.65.2",
    "@noir-lang/noir_js": "1.0.0-beta.0",
    "@shield-labs/zklogin-contracts": "0.5.0"
  }
